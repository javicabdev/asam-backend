# Logs
*.log

# Directorios de build
build/
dist/
/tmp/asam-backend

# IMPORTANTE: El código generado por gqlgen NO debe ignorarse
# ya que es necesario para compilar el proyecto.
# Los archivos en estos directorios están versionados:
# - /internal/adapters/gql/model/
# - /internal/adapters/gql/generated/
#
# Sin embargo, están excluidos del análisis de seguridad
# mediante .gosec.json y .golangci.yml

# Archivos temporales de generación
/internal/adapters/gql/model/*.tmp
/internal/adapters/gql/generated/*.tmp
/coverage*

# Scripts de prueba locales
test-linter.sh

# Archivos archivados
_archived/

# Archivos de seguridad locales
gosec-report.json
gosec-report.txt
/github-actions-sa-key.json
/docsTemp/
.DS_Store
