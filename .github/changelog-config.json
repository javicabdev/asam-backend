{
  "categories": [
    {
      "title": "## 🚀 Features",
      "labels": ["feature", "enhancement"]
    },
    {
      "title": "## 🐛 Bug Fixes",
      "labels": ["fix", "bug"]
    },
    {
      "title": "## 📝 Documentation",
      "labels": ["documentation"]
    },
    {
      "title": "## ⚙️ Build and CI",
      "labels": ["build", "ci"]
    },
    {
      "title": "## 🧪 Tests",
      "labels": ["test"]
    },
    {
      "title": "## 🔧 Maintenance",
      "labels": ["chore", "refactor"]
    },
    {
      "title": "## 📦 Dependencies",
      "labels": ["dependencies"]
    }
  ],
  "sort": "ASC",
  "template": "${{CHANGELOG}}\n\n## 🛠 Commits\n\n${{COMMITS}}",
  "pr_template": "- ${{TITLE}} (#${{NUMBER}})",
  "commit_template": "- ${{SUBJECT}} (${{COMMIT}})",
  "empty_template": "- No changes"
}