# Development Dockerfile with Go 1.24 runtime - SSL Fix
FROM golang:1.24-alpine

# Fix SSL issues for Alpine repositories (common in corporate environments)
RUN sed -i 's/https/http/g' /etc/apk/repositories

# Install dependencies including air for hot reload
RUN apk add --no-cache git ca-certificates make curl && \
    go env -w GOPROXY=https://proxy.golang.org,direct && \
    go env -w GOSUMDB=off && \
    go install github.com/air-verse/air@latest && \
    go install github.com/99designs/gqlgen@v0.17.73

# Environment variables
ENV GO111MODULE=on \
    CGO_ENABLED=0 \
    GOOS=linux \
    GOARCH=amd64 \
    GOPROXY=https://proxy.golang.org,direct \
    GOSUMDB=off

# Working directory
WORKDIR /app

# Copy go module files first for better caching
COPY go.mod go.sum ./

# Download dependencies with SSL workaround
RUN go mod download || (go env -w GOPROXY=direct && go mod download)

# Copy the rest of the source code
COPY . .

# Generate GraphQL code if needed
RUN if [ ! -f "internal/adapters/gql/generated/generated.go" ]; then \
        echo "=== Generating GraphQL code ===" && \
        mkdir -p internal/adapters/gql/generated internal/adapters/gql/model && \
        gqlgen generate; \
    fi

# Build the application (this will be rebuilt by air in development)
RUN go build -o asam-backend ./cmd/api

# Create directory for air tmp files
RUN mkdir -p /app/tmp

# Expose port
EXPOSE 8080

# Health check
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
    CMD wget --no-verbose --tries=1 --spider http://localhost:8080/health/live || exit 1

# Use air for hot reload in development
CMD ["air", "-c", ".air.toml"]
