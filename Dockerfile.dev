# Etapa 1: Construcción
FROM golang:1.23-alpine AS builder

# Configurar repositorios Alpine para usar HTTP
RUN echo 'http://dl-cdn.alpinelinux.org/alpine/v3.15/main' > /etc/apk/repositories && \
    echo 'http://dl-cdn.alpinelinux.org/alpine/v3.15/community' >> /etc/apk/repositories

# Instalar git (necesario para go mod download)
RUN apk add --no-cache git

# Variables de entorno para evitar problemas de certificados
ENV GO111MODULE=on \
    CGO_ENABLED=0 \
    GOOS=linux \
    GOARCH=amd64 \
    GOPROXY=direct \
    GOSUMDB=off \
    GIT_SSL_NO_VERIFY=true

# Directorio de trabajo dentro del contenedor
WORKDIR /app

# Copiar el go.mod y go.sum primero para aprovechar la caché de Docker
COPY go.mod go.sum ./

# Descargar las dependencias sin verificar certificados
RUN go env -w GOINSECURE=* && \
    git config --global http.sslVerify false && \
    go mod download

# Copiar el resto del código fuente
COPY . .

# Compilar la aplicación
RUN go build -o asam-backend ./cmd/api

# Etapa 2: Imagen Final
FROM alpine:3.15

# Configurar repositorios para usar HTTP
RUN echo 'http://dl-cdn.alpinelinux.org/alpine/v3.15/main' > /etc/apk/repositories && \
    echo 'http://dl-cdn.alpinelinux.org/alpine/v3.15/community' >> /etc/apk/repositories

# Instalar ca-certificates (opcional para la imagen final)
RUN apk --no-cache add ca-certificates

# Directorio de trabajo dentro del contenedor final
WORKDIR /root/

# Copiar el binario desde la etapa de construcción
COPY --from=builder /app/asam-backend .

# Variables de entorno para producción
ENV PORT=8080

# Exponer el puerto
EXPOSE 8080

# Comando para ejecutar la aplicación
CMD ["./asam-backend"]