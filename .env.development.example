# Configuración de la API
PORT=8080

# Configuración de PostgreSQL
# IMPORTANTE: Para Docker usar DB_HOST=postgres, para local usar DB_HOST=localhost
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=asam_db
DB_SSL_MODE=disable

# Pool de conexiones para desarrollo
DB_MAX_IDLE_CONNS=5
DB_MAX_OPEN_CONNS=15
DB_CONN_MAX_LIFETIME=2m

# Configuración JWT (REQUERIDO)
# Genera secretos seguros con: openssl rand -hex 32
JWT_ACCESS_SECRET=dev-access-secret-change-in-production
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-production
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# Configuraciones de Email (opcional)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=noreply@asam.org

# Rate Limiting
RATE_LIMIT_RPS=10
RATE_LIMIT_BURST=20
RATE_LIMIT_CLEANUP=1h

# Configuraciones adicionales
# debug, info, warn, error
LOG_LEVEL=debug
ENVIRONMENT=development
BASE_URL=http://localhost:8080

# ==================================================
# CONFIGURACIÓN DE USUARIO ADMINISTRADOR INICIAL
# ==================================================
# IMPORTANTE: Usar solo para crear el primer admin con:
# go run cmd/create-admin/main.go
# 
# NUNCA commitear estas variables con valores reales
# Después de crear el admin, puedes eliminar estos valores
# ==================================================
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=SecurePassword123!
# ADMIN_USERNAME=admin  # Opcional, si no se proporciona usa el email