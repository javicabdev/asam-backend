# Dockerfile.test
FROM golang:1.25-alpine

# Configurar repositorios Alpine para usar HTTP
RUN echo 'http://dl-cdn.alpinelinux.org/alpine/v3.15/main' > /etc/apk/repositories && \
    echo 'http://dl-cdn.alpinelinux.org/alpine/v3.15/community' >> /etc/apk/repositories

# Instalar git y herramientas necesarias
RUN apk add --no-cache git postgresql-client

# Variables de entorno
ENV GO111MODULE=on \
    CGO_ENABLED=0 \
    GOPROXY=direct \
    GOSUMDB=off \
    GIT_SSL_NO_VERIFY=true

# Configurar espacio de trabajo con la ruta correcta del módulo
WORKDIR /go/src/github.com/javicabdev/asam-backend

# Copiar código fuente
COPY . .

# Configurar Go para ignorar certificados SSL y descargar dependencias
RUN go env -w GOINSECURE=* && \
    git config --global http.sslVerify false && \
    go mod download

# Comando para ejecutar todos los tests (ahora se controla desde test.ps1)
CMD ["sh", "-c", "echo 'Esperando comando de test.ps1...' && tail -f /dev/null"]