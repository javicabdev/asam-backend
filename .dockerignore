# Archivos y directorios que Docker ignorará al construir la imagen

# Ignorar el directorio de módulos de Go
/vendor

# Ignorar archivos binarios
*.exe
*.exe~
*.dll
*.so
*.dylib
asam-backend

# Ignorar archivos de configuración locales
.env
.env.*
!.env.production.example

# Ignorar directorios de prueba y cobertura
/test
/coverage*
*.out
*.test
*.html

# Ignorar archivos de logs y temporales
*.log
*.tmp
/logs
/.tmp

# Ignorar el directorio .git y configuración
.git
.gitignore
.gitattributes

# Ignorar archivos de IDE
/.idea
/.vscode
*.swp
*.swo
*~
.DS_Store

# Ignorar Dockerfile y docker-compose
Dockerfile*
docker-compose*.yml
.dockerignore

# Ignorar documentación y scripts
README.md
IMPROVEMENTS.md
LICENSE
/.github
*.ps1
*.bat
*.sh

# Ignorar archivos de configuración de herramientas
.golangci.yml
.air.toml
gqlgen.yml
tools.go

# Ignorar archivos de análisis
/docs
coverage.txt
coverage.html

# Mantener el código fuente esencial
!/cmd/**
!/internal/**
!/pkg/**
!/migrations/**
!/go.mod
!/go.sum