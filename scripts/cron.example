# Cron configuration for ASAM Backend token maintenance
#
# This file contains example cron jobs for automatic token cleanup.
# Copy and adapt these lines to your system's crontab.
#
# To edit crontab: crontab -e
# To list current jobs: crontab -l

# Environment variables (adjust paths as needed)
SHELL=/bin/bash
PATH=/usr/local/bin:/usr/bin:/bin
ASAM_DIR=/path/to/asam-backend

# Daily token cleanup at 3:00 AM
0 3 * * * cd $ASAM_DIR && ./scripts/maintenance.sh --cleanup --report >> logs/maintenance.log 2>&1

# Enforce token limit every 6 hours
0 */6 * * * cd $ASAM_DIR && ./scripts/maintenance.sh --limit --token-limit 5 >> logs/maintenance.log 2>&1

# Full maintenance every Sunday at 2:00 AM
0 2 * * 0 cd $ASAM_DIR && ./scripts/maintenance.sh --all --report >> logs/maintenance.log 2>&1

# Alternative: Using Go binary directly (if compiled)
# 0 3 * * * /usr/local/bin/asam-maintenance -cleanup-tokens -report >> /var/log/asam/maintenance.log 2>&1

# Alternative: Using systemd timer (modern approach)
# Create /etc/systemd/system/asam-token-cleanup.service and asam-token-cleanup.timer
