# ========================================
# ASAM Backend - Environment Configuration
# ========================================
# Copy this file to .env and configure with your values
# cp .env.example .env

# ========================================
# GENERAL CONFIGURATION
# ========================================
ENVIRONMENT=development
PORT=8080

# ========================================
# DATABASE CONFIGURATION (PostgreSQL)
# ========================================
# For Docker: use DB_HOST=postgres
# For local: use DB_HOST=localhost
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=asam_db
DB_SSL_MODE=disable

# Database connection pool
DB_MAX_IDLE_CONNS=5
DB_MAX_OPEN_CONNS=15
DB_CONN_MAX_LIFETIME=2m

# ========================================
# JWT CONFIGURATION
# ========================================
# REQUIRED: Generate secure secrets with: openssl rand -hex 32
JWT_ACCESS_SECRET=dev-access-secret-change-in-production
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-production
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# ========================================
# EMAIL CONFIGURATION
# ========================================

# SMTP (DEPRECATED - kept for backwards compatibility)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=noreply@asam.org

# MailerSend (RECOMMENDED)
# REQUIRED: Get your API key from https://app.mailersend.com
# For local email testing, use a real API key
MAILERSEND_API_KEY=your-mailersend-api-key-here
MAILERSEND_FROM_EMAIL=noreply@asam.org
MAILERSEND_FROM_NAME=ASAM

# ========================================
# RATE LIMITING
# ========================================
RATE_LIMIT_RPS=10
RATE_LIMIT_BURST=20
RATE_LIMIT_CLEANUP=1h

# Login rate limiting
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_DURATION=15m
LOGIN_WINDOW_DURATION=5m

# ========================================
# MONITORING & PERFORMANCE
# ========================================
ENABLE_PROFILING=true
PROFILING_PORT=6060
LOG_SLOW_QUERIES=true
SLOW_QUERY_THRESHOLD=100ms
LOG_SLOW_RESOLVERS=true
SLOW_RESOLVER_THRESHOLD=100ms
MEM_PROFILE_DIR=logs/memory-profiles
MEM_ALERT_THRESHOLD=200
MEM_CRITICAL_THRESHOLD=500

# ========================================
# GRAPHQL CONFIGURATION
# ========================================
GQL_COMPLEXITY_LIMIT=1000
GQL_CONCURRENT_RESOLVERS=10

# ========================================
# TOKEN MANAGEMENT
# ========================================
MAX_TOKENS_PER_USER=5
TOKEN_CLEANUP_ENABLED=true
TOKEN_CLEANUP_INTERVAL=24h

# ========================================
# APPLICATION SETTINGS
# ========================================
BASE_URL=http://localhost:8080
LOG_LEVEL=debug
