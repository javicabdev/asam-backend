# Production environment variables for ASAM Backend
# Copy this file to .env.production and fill in the values

# General Configuration
ENVIRONMENT=production
# PORT is automatically set by Cloud Run - DO NOT SET IT HERE

# Database Configuration (Aiven PostgreSQL)
DB_HOST=pg-asam-asam-backend-db.l.aivencloud.com
DB_PORT=14276
DB_USER=avnadmin
DB_PASSWORD=your-db-password-here
DB_NAME=asam-backend-db
DB_SSL_MODE=require

# JWT Configuration (REQUIRED - Use strong random values)
JWT_ACCESS_SECRET=your-strong-random-access-secret-here
JWT_REFRESH_SECRET=your-strong-random-refresh-secret-here
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# Admin Credentials (REQUIRED for production)
ADMIN_USER=admin
ADMIN_PASSWORD=your-strong-admin-password-here

# SMTP Configuration (REQUIRED for notifications)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=noreply@asam.org

# Rate Limiting
RATE_LIMIT_RPS=10
RATE_LIMIT_BURST=20

# Monitoring and Performance
ENABLE_PROFILING=false
LOG_SLOW_QUERIES=true
SLOW_QUERY_THRESHOLD=100ms
LOG_SLOW_RESOLVERS=true
SLOW_RESOLVER_THRESHOLD=100ms

# GraphQL Configuration
GQL_COMPLEXITY_LIMIT=1000
GQL_CONCURRENT_RESOLVERS=10
