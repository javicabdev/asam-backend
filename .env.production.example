# Configuración del servidor
ENVIRONMENT=production
PORT=8080

# Configuración de la base de datos
DB_HOST=YOUR_PRODUCTION_DB_HOST
DB_PORT=5432
DB_USER=YOUR_PRODUCTION_DB_USER
DB_PASSWORD=YOUR_PRODUCTION_DB_PASSWORD
DB_NAME=asam_prod
DB_SSL_MODE=require

# Optimización del pool de conexiones
DB_MAX_IDLE_CONNS=10
DB_MAX_OPEN_CONNS=50
DB_CONN_MAX_LIFETIME=15m

# Configuración JWT (cambiar estos valores)
JWT_ACCESS_SECRET=YOUR_PRODUCTION_JWT_ACCESS_SECRET
JWT_REFRESH_SECRET=YOUR_PRODUCTION_JWT_REFRESH_SECRET
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# Límites de tasa para prevenir ataques
RATE_LIMIT_RPS=20
RATE_LIMIT_BURST=40
RATE_LIMIT_CLEANUP=1h

# Configuración SMTP
SMTP_SERVER=YOUR_SMTP_SERVER
SMTP_PORT=587
SMTP_USER=YOUR_SMTP_USER
SMTP_PASSWORD=YOUR_SMTP_PASSWORD
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=noreply@your-domain.com

# Configuración de monitoreo y rendimiento
ENABLE_PROFILING=false
PROFILING_PORT=6060
LOG_SLOW_QUERIES=true
SLOW_QUERY_THRESHOLD=100ms
LOG_SLOW_RESOLVERS=true
SLOW_RESOLVER_THRESHOLD=100ms
MEM_PROFILE_DIR=logs/memory-profiles
MEM_ALERT_THRESHOLD=200
MEM_CRITICAL_THRESHOLD=500

# Credenciales de admin para endpoints de monitoreo
ADMIN_USER=YOUR_ADMIN_USER
ADMIN_PASSWORD=YOUR_SECURE_ADMIN_PASSWORD

# Límites de GraphQL
GQL_COMPLEXITY_LIMIT=1000
GQL_CONCURRENT_RESOLVERS=10
