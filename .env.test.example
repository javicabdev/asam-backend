# Test Environment Configuration
# Copy this file to .env.test for running tests

# Environment
ENVIRONMENT=test
PORT=8080

# PostgreSQL Test Database Configuration
# These values should match your test database setup
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=asam_test_db
DB_SSL_MODE=disable

# Connection Pool Settings for Tests
DB_MAX_IDLE_CONNS=2
DB_MAX_OPEN_CONNS=5
DB_CONN_MAX_LIFETIME=1m

# JWT Configuration for Tests
JWT_ACCESS_SECRET=test-access-secret-for-ci
JWT_REFRESH_SECRET=test-refresh-secret-for-ci
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Test-specific settings
LOG_LEVEL=debug
LOG_FORMAT=text
ENABLE_PROFILING=false

# Email settings (mock for tests)
SMTP_SERVER=smtp.example.com
SMTP_PORT=587
SMTP_USER=test@example.com
SMTP_PASSWORD=test-password
SMTP_USE_TLS=false
SMTP_FROM_EMAIL=noreply-test@asam.org

# Admin credentials for tests
ADMIN_USER=admin
ADMIN_PASSWORD=admin-test-password