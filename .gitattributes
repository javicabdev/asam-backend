# Git attributes configuration

# Ensure consistent line endings for all text files
* text=auto

# Ensure LF line endings for shell scripts and Dockerfiles
*.sh text eol=lf
Dockerfile text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Go files
*.go text eol=lf
go.mod text eol=lf
go.sum text eol=lf

# Markdown files
*.md text eol=lf

# Configuration files
*.json text eol=lf
*.toml text eol=lf
*.xml text eol=lf

# SQL files
*.sql text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary
*.exe binary
